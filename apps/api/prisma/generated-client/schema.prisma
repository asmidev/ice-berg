generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                     String                  @id @default(uuid())
  name                   String
  domain                 String?                 @unique
  plan                   String                  @default("Starter")
  settings               Json?
  created_at             DateTime                @default(now())
  archiveReasons         ArchiveReason[]
  autoSmsConfigs         AutoSmsConfig[]
  bonuses                Bonus[]
  bonusSources           BonusSource[]
  teacherAttendances     TeacherAttendance[]
  branches               Branch[]
  callCenterTasks        CallCenterTask[]
  cashboxes              Cashbox[]
  cashflowTransfers      CashflowTransfer[]
  courses                Course[]
  customers              Customer[]
  departments            Department[]
  discounts              Discount[]
  expenses               Expense[]
  expenseCategories      ExpenseCategory[]
  expensePlans           ExpensePlan[]
  groups                 Group[]
  invoices               Invoice[]
  leads                  Lead[]
  leadSources            LeadSource[]
  leadStages             LeadStage[]
  notifications          Notification[]
  payments               Payment[]
  paymentCategories      PaymentCategory[]
  payrolls               Payroll[]
  products               Product[]
  productCategories      ProductCategory[]
  receiptTemplates       ReceiptTemplate[]
  rooms                  Room[]
  saleTransactions       SaleTransaction[]
  smsLogs                SmsLog[]
  smsTemplates           SmsTemplate[]
  staff                  Staff[]
  students               Student[]
  studentArchiveReasons  StudentArchiveReason[]
  teachers               Teacher[]
  teacherArchiveReasons  TeacherArchiveReason[]
  teacherSpecializations TeacherSpecialization[]
  users                  User[]
  penalties              Penalty[]
  staffAttendances       StaffAttendance[]
}

model ReceiptTemplate {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  settings   Json
  created_at DateTime @default(now())
  branch_id  String?
  branch     Branch?  @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Branch {
  id                String             @id @default(uuid())
  tenant_id         String
  name              String
  address           String?
  created_at        DateTime           @default(now())
  settings          Json?
  autoSmsConfigs    AutoSmsConfig[]
  bonuses           Bonus[]
  callCenterTasks   CallCenterTask[]
  tenant            Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cashboxes         Cashbox[]
  cashflowTransfers CashflowTransfer[]
  courses           Course[]
  customers         Customer[]
  expenses          Expense[]
  expensePlans      ExpensePlan[]
  groups            Group[]
  invoices          Invoice[]
  leads             Lead[]
  payments          Payment[]
  payrolls          Payroll[]
  products          Product[]
  receiptTemplates  ReceiptTemplate[]
  rooms             Room[]
  saleTransactions  SaleTransaction[]
  smsLogs           SmsLog[]
  staff             Staff[]
  students          Student[]
  teachers          Teacher[]
  users             User[]             @relation("BranchToUser")
  smsTemplates      SmsTemplate[]
  paymentCategories PaymentCategory[]
  penalties         Penalty[]
  staffAttendances  StaffAttendance[]
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  permissions String[]
  users       User[]
}

model User {
  id                  String             @id @default(uuid())
  tenant_id           String
  phone               String             @unique
  email               String?
  password_hash       String
  role_id             String
  is_active           Boolean            @default(true)
  created_at          DateTime           @default(now())
  first_name          String?
  last_name           String?
  gender              String?
  photo_url           String?
  createdTransfers    CashflowTransfer[]
  crmTasks            CrmTask[]
  expensesCreated     Expense[]
  responsibleExpenses Expense[]          @relation("ResponsibleUser")
  staffExpenses       Expense[]          @relation("StaffUser")
  managedLeads        Lead[]
  paymentsHandled     Payment[]
  salesHandled        SaleTransaction[]
  callCenterTasks     CallCenterTask[]
  staffProfile        Staff?
  studentProfile      Student?
  teacherProfile      Teacher?
  role                Role               @relation(fields: [role_id], references: [id])
  tenant              Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  branches            Branch[]           @relation("BranchToUser")
}

model Teacher {
  id              String              @id @default(uuid())
  tenant_id       String
  user_id         String              @unique
  branch_id       String?
  specialization  String?
  salary_type     String              @default("FIXED")
  salary_amount   Decimal             @default(0) @db.Decimal(10, 2)
  joined_at       DateTime            @default(now())
  date_of_birth   DateTime?
  description     String?
  archive_reason  String?
  archived_at     DateTime?
  is_archived     Boolean             @default(false)
  type            String              @default("MAIN")
  bonuses         Bonus[]
  supportedGroups Group[]             @relation("SupportTeacher")
  taughtGroups    Group[]             @relation("MainTeacher")
  payrolls        Payroll[]
  branch          Branch?             @relation(fields: [branch_id], references: [id])
  tenant          Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  feedbacks       TeacherFeedback[]
  performance     TeacherPerformance?
  penalties       Penalty[]
  attendances     TeacherAttendance[]
}

model TeacherAttendance {
  id           String   @id @default(uuid())
  tenant_id    String
  teacher_id   String
  schedule_id  String
  date         DateTime @db.Date
  status       String // PRESENT, LATE, ABSENT
  late_minutes Int      @default(0)
  note         String?
  created_at   DateTime @default(now())

  teacher  Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([teacher_id, schedule_id, date])
}

model StaffAttendance {
  id         String   @id @default(uuid())
  tenant_id  String
  staff_id   String
  branch_id  String?
  date       DateTime @db.Date
  status     String // PRESENT, ABSENT, LATE
  delay_time Int      @default(0) // in minutes
  note       String?
  created_at DateTime @default(now())

  staff  Staff   @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branch_id], references: [id])
  tenant Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([staff_id, date])
}

model TeacherPerformance {
  id                 String   @id @default(uuid())
  teacher_id         String   @unique
  grading_timeliness Float    @default(0)
  avg_grade          Float    @default(0)
  attendance_rate    Float    @default(0)
  last_updated       DateTime @default(now())
  teacher            Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model TeacherFeedback {
  id         String   @id @default(uuid())
  teacher_id String
  student_id String?
  rating     Int      @default(5)
  comment    String?
  created_at DateTime @default(now())
  student    Student? @relation(fields: [student_id], references: [id])
  teacher    Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

model TeacherArchiveReason {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model TeacherSpecialization {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Staff {
  id             String            @id @default(uuid())
  tenant_id      String
  user_id        String            @unique
  branch_id      String?
  position       String?
  salary         Decimal           @default(0) @db.Decimal(10, 2)
  archive_reason String?
  archived_at    DateTime?
  is_archived    Boolean           @default(false)
  bonuses        Bonus[]
  payrolls       Payroll[]
  branch         Branch?           @relation(fields: [branch_id], references: [id])
  tenant         Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  attendances    StaffAttendance[]
}

model Student {
  id               String            @id @default(uuid())
  tenant_id        String
  user_id          String            @unique
  status           StudentStatus     @default(ACTIVE)
  parent_id        String?
  joined_at        DateTime          @default(now())
  balance          Decimal           @default(0) @db.Decimal(10, 2)
  branch_id        String?
  archive_reason   String?
  is_archived      Boolean           @default(false)
  parent_phone     String?
  tags             String[]          @default([])
  archived_at      DateTime?
  date_of_birth    DateTime?
  book_balance     Decimal           @default(0) @db.Decimal(10, 2)
  course_balance   Decimal           @default(0) @db.Decimal(10, 2)
  mock_balance     Decimal           @default(0) @db.Decimal(10, 2)
  lead_id          String?           @unique
  is_vip           Boolean           @default(false)
  enrollments      Enrollment[]
  grades           Grade[]
  invoices         Invoice[]
  payments         Payment[]
  saleTransactions SaleTransaction[]
  branch           Branch?           @relation(fields: [branch_id], references: [id])
  lead             Lead?             @relation("LeadToStudent", fields: [lead_id], references: [id])
  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  discounts        StudentDiscount[]
  submissions      Submission[]
  teacherFeedbacks TeacherFeedback[]
  callCenterTasks  CallCenterTask[]
}

model LeadStage {
  id        String  @id @default(uuid())
  tenant_id String
  name      String
  color     String?
  order     Int     @default(0)
  leads     Lead[]
  tenant    Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model LeadSource {
  id        String  @id @default(uuid())
  tenant_id String
  name      String
  slug      String?
  leads     Lead[]
  tenant    Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model ArchiveReason {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model StudentArchiveReason {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Lead {
  id             String      @id @default(uuid())
  tenant_id      String
  name           String
  phone          String
  manager_id     String?
  notes          String?
  created_at     DateTime    @default(now())
  branch_id      String?
  source_id      String?
  stage_id       String?
  archive_reason String?
  status         String      @default("ACTIVE")
  converted_at   DateTime?
  crmTasks       CrmTask[]
  branch         Branch?     @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  manager        User?       @relation(fields: [manager_id], references: [id])
  source         LeadSource? @relation(fields: [source_id], references: [id])
  stage          LeadStage?  @relation(fields: [stage_id], references: [id])
  tenant         Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  student        Student?    @relation("LeadToStudent")
  course_id      String?
  course         Course?     @relation(fields: [course_id], references: [id])
}

model CrmTask {
  id         String   @id @default(uuid())
  lead_id    String
  manager_id String
  title      String
  deadline   DateTime
  status     String   @default("PENDING")
  created_at DateTime @default(now())
  lead       Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  manager    User     @relation(fields: [manager_id], references: [id], onDelete: Cascade)
}

model Course {
  id          String  @id @default(uuid())
  tenant_id   String
  name        String
  description String?
  branch_id   String?
  branch      Branch? @relation(fields: [branch_id], references: [id])
  tenant      Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  groups      Group[]
  leads       Lead[]
}

model Group {
  id                    String           @id @default(uuid())
  tenant_id             String
  course_id             String
  teacher_id            String?
  room_id               String?
  name                  String
  capacity              Int
  start_date            DateTime
  branch_id             String?
  current_stage         Int              @default(1)
  end_date              DateTime?
  last_stage_at         DateTime         @default(now())
  price                 Decimal          @default(0) @db.Decimal(10, 2)
  stage_duration_months Int              @default(1)
  status                String           @default("ACTIVE")
  support_teacher_id    String?
  total_stages          Int              @default(1)
  description           String?
  is_online             Boolean          @default(false)
  main_teacher_days     Int              @default(0)
  support_teacher_days  Int              @default(0)
  telegram_chat_id      String?
  archive_reason        String?
  archived_at           DateTime?
  is_archived           Boolean          @default(false)
  is_vip                Boolean          @default(false)
  teacher_salary_type   String           @default("PERCENT_REVENUE")
  teacher_salary_value  Decimal          @default(0) @db.Decimal(10, 2)
  support_salary_type   String?          @default("FIXED")
  support_salary_value  Decimal?         @default(0) @db.Decimal(10, 2)
  assignments           Assignment[]
  enrollments           Enrollment[]
  exams                 Exam[]
  branch                Branch?          @relation(fields: [branch_id], references: [id])
  course                Course           @relation(fields: [course_id], references: [id], onDelete: Cascade)
  room                  Room?            @relation(fields: [room_id], references: [id])
  support_teacher       Teacher?         @relation("SupportTeacher", fields: [support_teacher_id], references: [id])
  teacher               Teacher?         @relation("MainTeacher", fields: [teacher_id], references: [id])
  tenant                Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invoices              Invoice[]
  payments              Payment[]
  schedules             Schedule[]
  penalties             Penalty[]
  revenueSegments       RevenueSegment[]
  payrolls              Payroll[]
}

model Room {
  id          String     @id @default(uuid())
  tenant_id   String
  branch_id   String
  name        String
  capacity    Int?
  description String?
  created_at  DateTime   @default(now())
  is_active   Boolean    @default(true)
  groups      Group[]
  branch      Branch     @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant      Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  schedules   Schedule[]
}

model Enrollment {
  id          String       @id @default(uuid())
  student_id  String
  group_id    String
  enrolled_at DateTime     @default(now())
  status      String       @default("ACTIVE")
  attendances Attendance[]
  group       Group        @relation(fields: [group_id], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Schedule {
  id                 String              @id @default(uuid())
  group_id           String
  day_of_week        Int
  start_time         String
  end_time           String
  room_id            String?
  attendances        Attendance[]
  penalties          Penalty[]
  group              Group               @relation(fields: [group_id], references: [id], onDelete: Cascade)
  room               Room?               @relation(fields: [room_id], references: [id])
  teacherAttendances TeacherAttendance[]
}

model Attendance {
  id            String     @id @default(uuid())
  enrollment_id String
  schedule_id   String
  date          DateTime   @db.Date
  status        String
  score         Int?
  marked_by     String?
  marked_at     DateTime   @default(now())
  enrollment    Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  schedule      Schedule   @relation(fields: [schedule_id], references: [id], onDelete: Cascade)

  @@unique([enrollment_id, schedule_id, date])
}

model Cashbox {
  id                   String             @id @default(uuid())
  tenant_id            String
  branch_id            String
  name                 String
  balance              Decimal            @default(0) @db.Decimal(12, 2)
  created_at           DateTime           @default(now())
  balance_other        Decimal            @default(0) @db.Decimal(12, 2)
  type                 String             @default("PHYSICAL")
  bonuses              Bonus[]
  branch               Branch             @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant               Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  destinationTransfers CashflowTransfer[] @relation("DestinationCashbox")
  sourceTransfers      CashflowTransfer[] @relation("SourceCashbox")
  expenses             Expense[]
  payments             Payment[]
  payrolls             Payroll[]
  saleTransactions     SaleTransaction[]
}

model CashflowTransfer {
  id             String   @id @default(uuid())
  tenant_id      String
  branch_id      String?
  source_id      String?
  destination_id String?
  amount_cash    Decimal  @default(0) @db.Decimal(12, 2)
  amount_other   Decimal  @default(0) @db.Decimal(12, 2)
  type           String
  description    String?
  created_at     DateTime @default(now())
  created_by     String?
  branch         Branch?  @relation(fields: [branch_id], references: [id])
  creator        User?    @relation(fields: [created_by], references: [id])
  destination    Cashbox? @relation("DestinationCashbox", fields: [destination_id], references: [id])
  source         Cashbox? @relation("SourceCashbox", fields: [source_id], references: [id])
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Payment {
  id              String           @id @default(uuid())
  tenant_id       String
  student_id      String
  amount          Decimal          @db.Decimal(10, 2)
  type            String
  cashier_id      String?
  created_at      DateTime         @default(now())
  branch_id       String?
  cashbox_id      String?
  description     String?
  external_id     String?
  group_id        String?
  status          String           @default("SUCCESS")
  archive_reason  String?
  archived_at     DateTime?
  is_archived     Boolean          @default(false)
  invoice_id      String?
  paid_for_month  String?
  branch          Branch?          @relation(fields: [branch_id], references: [id])
  cashbox         Cashbox?         @relation(fields: [cashbox_id], references: [id])
  cashier         User?            @relation(fields: [cashier_id], references: [id])
  group           Group?           @relation(fields: [group_id], references: [id])
  invoice         Invoice?         @relation(fields: [invoice_id], references: [id])
  student         Student          @relation(fields: [student_id], references: [id])
  tenant          Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  transaction     Transaction?
  category_id     String?
  category        PaymentCategory? @relation(fields: [category_id], references: [id])
  revenueSegments RevenueSegment[]
}

model PaymentCategory {
  id         String    @id @default(uuid())
  tenant_id  String
  branch_id  String?
  name       String
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  payments   Payment[]
  branch     Branch?   @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String    @id @default(uuid())
  tenant_id   String
  branch_id   String?
  student_id  String
  group_id    String?
  amount      Decimal   @db.Decimal(10, 2)
  paid_amount Decimal   @default(0) @db.Decimal(10, 2)
  status      String    @default("UNPAID")
  type        String    @default("COURSE")
  month       String
  created_at  DateTime  @default(now())
  branch      Branch?   @relation(fields: [branch_id], references: [id])
  group       Group?    @relation(fields: [group_id], references: [id])
  student     Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  start_date  DateTime?
  end_date    DateTime?
  payments    Payment[]
}

model Expense {
  id             String           @id @default(uuid())
  tenant_id      String
  amount         Decimal          @db.Decimal(10, 2)
  category       String
  description    String?
  date           DateTime         @default(now())
  created_by     String?
  branch_id      String?
  cashbox_id     String?
  archive_reason String?
  archived_at    DateTime?
  category_id    String?
  department_id  String?
  is_archived    Boolean          @default(false)
  payment_method String?          @default("CASH")
  responsible_id String?
  source_type    String?          @default("KASSA")
  staff_id       String?
  type           String           @default("VARIABLE")
  branch         Branch?          @relation(fields: [branch_id], references: [id])
  cashbox        Cashbox?         @relation(fields: [cashbox_id], references: [id])
  categoryRel    ExpenseCategory? @relation(fields: [category_id], references: [id])
  creator        User?            @relation(fields: [created_by], references: [id])
  department     Department?      @relation(fields: [department_id], references: [id])
  responsible    User?            @relation("ResponsibleUser", fields: [responsible_id], references: [id])
  staff          User?            @relation("StaffUser", fields: [staff_id], references: [id])
  tenant         Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Department {
  id        String    @id @default(uuid())
  tenant_id String
  name      String
  tenant    Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  expenses  Expense[]
}

model ExpenseCategory {
  id        String        @id @default(uuid())
  tenant_id String
  name      String
  is_active Boolean       @default(true)
  expenses  Expense[]
  tenant    Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  plans     ExpensePlan[]
}

model ExpensePlan {
  id          String          @id @default(uuid())
  tenant_id   String
  branch_id   String?
  category_id String
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  created_at  DateTime        @default(now())
  branch      Branch?         @relation(fields: [branch_id], references: [id])
  category    ExpenseCategory @relation(fields: [category_id], references: [id])
  tenant      Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Transaction {
  id             String   @id @default(uuid())
  payment_id     String   @unique
  amount         Decimal  @db.Decimal(10, 2)
  balance_before Decimal  @db.Decimal(12, 2)
  balance_after  Decimal  @db.Decimal(12, 2)
  created_at     DateTime @default(now())
  payment        Payment  @relation(fields: [payment_id], references: [id], onDelete: Cascade)
}

model Payroll {
  id             String           @id @default(uuid())
  tenant_id      String
  teacher_id     String?
  amount         Decimal          @db.Decimal(10, 2)
  period         String
  status         String           @default("PENDING")
  paid_at        DateTime?
  created_at     DateTime         @default(now())
  bonus          Decimal          @default(0) @db.Decimal(10, 2)
  branch_id      String?
  deduction      Decimal          @default(0) @db.Decimal(10, 2)
  staff_id       String?
  archive_reason String?
  archived_at    DateTime?
  cashbox_id     String?
  description    String?
  is_archived    Boolean          @default(false)
  payment_method String?          @default("CASH")
  type           String?
  group_id       String?
  branch         Branch?          @relation(fields: [branch_id], references: [id])
  group          Group?           @relation(fields: [group_id], references: [id])
  cashbox        Cashbox?         @relation(fields: [cashbox_id], references: [id])
  staff          Staff?           @relation(fields: [staff_id], references: [id])
  teacher        Teacher?         @relation(fields: [teacher_id], references: [id])
  segments       PayrollSegment[]
  tenant         Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Exam {
  id        String   @id @default(uuid())
  group_id  String
  title     String
  date      DateTime
  max_score Int
  group     Group    @relation(fields: [group_id], references: [id], onDelete: Cascade)
  grades    Grade[]
}

model Grade {
  id         String   @id @default(uuid())
  exam_id    String
  student_id String
  score      Int
  feedback   String?
  created_at DateTime @default(now())
  exam       Exam     @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Assignment {
  id          String       @id @default(uuid())
  group_id    String
  title       String
  deadline    DateTime
  max_score   Int
  group       Group        @relation(fields: [group_id], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Submission {
  id            String     @id @default(uuid())
  assignment_id String
  student_id    String
  score         Int?
  submitted_at  DateTime   @default(now())
  feedback      String?
  assignment    Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  student       Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Discount {
  id         String            @id @default(uuid())
  tenant_id  String
  name       String
  type       String
  value      Decimal           @db.Decimal(10, 2)
  is_active  Boolean           @default(true)
  created_at DateTime          @default(now())
  tenant     Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  appliedTo  StudentDiscount[]
}

model StudentDiscount {
  id          String    @id @default(uuid())
  student_id  String
  discount_id String
  granted_at  DateTime  @default(now())
  expires_at  DateTime?
  discount    Discount  @relation(fields: [discount_id], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model Notification {
  id           String    @id @default(uuid())
  tenant_id    String
  type         String
  channel      String
  recipient_id String
  status       String
  sent_at      DateTime?
  created_at   DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id         String    @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime  @default(now())
  products   Product[]
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Product {
  id          String           @id @default(uuid())
  tenant_id   String
  branch_id   String?
  category_id String?
  name        String
  stock       Int              @default(0)
  price       Decimal          @db.Decimal(10, 2)
  cost_price  Decimal          @default(0) @db.Decimal(10, 2)
  is_for_sale Boolean          @default(true)
  is_top      Boolean          @default(false)
  photo_url   String?
  created_at  DateTime         @default(now())
  branch      Branch?          @relation(fields: [branch_id], references: [id])
  category    ProductCategory? @relation(fields: [category_id], references: [id])
  tenant      Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  saleItems   SaleItem[]
}

model Customer {
  id         String            @id @default(uuid())
  tenant_id  String
  branch_id  String?
  name       String
  phone      String?
  created_at DateTime          @default(now())
  branch     Branch?           @relation(fields: [branch_id], references: [id])
  tenant     Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales      SaleTransaction[]
}

model SaleTransaction {
  id             String     @id @default(uuid())
  tenant_id      String
  branch_id      String?
  amount         Decimal    @db.Decimal(10, 2)
  payment_method String     @default("CASH")
  student_id     String?
  customer_id    String?
  staff_id       String?
  cashbox_id     String?
  status         String     @default("SUCCESS")
  description    String?
  created_at     DateTime   @default(now())
  archive_reason String?
  archived_at    DateTime?
  is_archived    Boolean    @default(false)
  items          SaleItem[]
  branch         Branch?    @relation(fields: [branch_id], references: [id])
  cashbox        Cashbox?   @relation(fields: [cashbox_id], references: [id])
  customer       Customer?  @relation(fields: [customer_id], references: [id])
  staff          User?      @relation(fields: [staff_id], references: [id])
  student        Student?   @relation(fields: [student_id], references: [id])
  tenant         Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model SaleItem {
  id            String          @id @default(uuid())
  sale_id       String
  product_id    String
  quantity      Int
  price_at_sale Decimal         @db.Decimal(10, 2)
  product       Product         @relation(fields: [product_id], references: [id])
  sale          SaleTransaction @relation(fields: [sale_id], references: [id], onDelete: Cascade)
}

model BonusSource {
  id        String  @id @default(uuid())
  tenant_id String
  name      String
  is_active Boolean @default(true)
  bonuses   Bonus[]
  tenant    Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Bonus {
  id             String       @id @default(uuid())
  tenant_id      String
  branch_id      String?
  teacher_id     String?
  staff_id       String?
  amount         Decimal      @db.Decimal(10, 2)
  reason         String
  source_id      String?
  date           DateTime     @default(now())
  payment_method String?      @default("CASH")
  cashbox_id     String?
  created_at     DateTime     @default(now())
  is_archived    Boolean      @default(false)
  archive_reason String?
  archived_at    DateTime?
  branch         Branch?      @relation(fields: [branch_id], references: [id])
  cashbox        Cashbox?     @relation(fields: [cashbox_id], references: [id])
  source         BonusSource? @relation(fields: [source_id], references: [id])
  staff          Staff?       @relation(fields: [staff_id], references: [id])
  teacher        Teacher?     @relation(fields: [teacher_id], references: [id])
  tenant         Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model SmsTemplate {
  id         String          @id @default(uuid())
  tenant_id  String
  branch_id  String?
  name       String
  text       String
  is_active  Boolean         @default(true)
  created_at DateTime        @default(now())
  configs    AutoSmsConfig[]
  branch     Branch?         @relation(fields: [branch_id], references: [id])
  tenant     Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model AutoSmsConfig {
  id             String      @id @default(uuid())
  tenant_id      String
  branch_id      String?
  template_id    String
  type           String      @default("DEBTOR") // DEBTOR, PAYMENT, ENROLLMENT
  scheduled_day  Int         @default(5)
  scheduled_time String      @default("10:00")
  is_enabled     Boolean     @default(true)
  created_at     DateTime    @default(now())
  branch         Branch?     @relation(fields: [branch_id], references: [id])
  template       SmsTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  tenant         Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model Penalty {
  id           String    @id @default(uuid())
  tenant_id    String
  teacher_id   String
  group_id     String?
  schedule_id  String?
  amount       Decimal   @db.Decimal(10, 2)
  reason       String
  date         DateTime  @default(now())
  is_automated Boolean   @default(true)
  created_at   DateTime  @default(now())
  branch_id    String?
  branch       Branch?   @relation(fields: [branch_id], references: [id])
  group        Group?    @relation(fields: [group_id], references: [id])
  schedule     Schedule? @relation(fields: [schedule_id], references: [id])
  teacher      Teacher   @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([teacher_id])
  @@index([date])
}

model SmsLog {
  id        String   @id @default(uuid())
  tenant_id String
  branch_id String?
  phone     String
  message   String
  status    String   @default("SENT")
  sent_at   DateTime @default(now())
  branch    Branch?  @relation(fields: [branch_id], references: [id])
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

enum StudentStatus {
  LEAD
  TRIAL
  ACTIVE
  FROZEN
  DEBTOR
  GRADUATED
  REMOVED
}

model RevenueSegment {
  id         String   @id @default(uuid())
  tenant_id  String
  branch_id  String?
  payment_id String
  amount     Decimal  @db.Decimal(10, 2)
  date       DateTime // Month recognition date (1st of month)
  group_id   String?
  type       String   @default("COURSE")
  payment    Payment  @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  group      Group?   @relation(fields: [group_id], references: [id])
  created_at DateTime @default(now())

  @@index([tenant_id, date])
}

model PayrollSegment {
  id         String   @id @default(uuid())
  tenant_id  String
  branch_id  String?
  payroll_id String
  amount     Decimal  @db.Decimal(10, 2)
  date       DateTime // Month recognition date (1st of month)
  payroll    Payroll  @relation(fields: [payroll_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@index([tenant_id, date])
}

model CallCenterTask {
  id            String    @id @default(uuid())
  tenant_id     String
  branch_id     String?
  student_id    String
  staff_id      String? // Operator who handled the call
  type          String // 'DEBTOR', 'NEW_LEAD', 'ABSENTEE'
  status        String    @default("PENDING") // 'PENDING', 'CALLED', 'RESOLVED'
  last_call_at  DateTime?
  next_call_at  DateTime?
  promised_date DateTime?
  note          String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  branch  Branch? @relation(fields: [branch_id], references: [id])
  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  staff   User?   @relation(fields: [staff_id], references: [id])
  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([branch_id])
  @@index([student_id])
  @@index([staff_id])
  @@index([status])
}
